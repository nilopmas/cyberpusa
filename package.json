{
  "name": "cyberpusa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Workers-first Cloudflare-native headless CMS framework scaffold",
  "scripts": {
    "dev": "wrangler dev src/server.ts",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "check": "npm run typecheck && npm run test"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.12",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250303.0",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.6.2",
    "drizzle-kit": "^0.27.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^3.109.2"
  }
}
